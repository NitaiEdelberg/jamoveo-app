# Frontend build-time config (Vite bakes these at BUILD time).
# Point this at your deployed backend. Used by every axios call AND socket.io.
# Local dev:  VITE_API_URL=http://localhost:3001
# Production: VITE_API_URL=https://jamoveo-backend.onrender.com   (your Render URL, no trailing slash)
VITE_API_URL=http://localhost:3001
