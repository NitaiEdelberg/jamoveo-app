# Backend environment variables. Copy to .env for local dev (never commit .env).
# Supabase Postgres connection string (Project Settings -> Database -> Connection string -> URI)
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/postgres
# Secret used to sign JWTs. Use a long random string in production.
JWT_SECRET=change-me-to-a-long-random-string
# Optional: local port (Render/host sets this automatically in production)
PORT=3001
